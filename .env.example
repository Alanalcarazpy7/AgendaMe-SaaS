# Copiar a .env.local y completar con valores reales. Nunca commitear .env.local.

# --- Supabase (cliente público) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (solo servidor, privilegiado) ---
# NUNCA exponer con prefijo NEXT_PUBLIC_. Nunca importar en Client Components.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional pero recomendado en produccion. Se usa solo para HMAC de claves de
# rate limit; generar un valor aleatorio largo y guardarlo tambien en Vercel.
# Si falta, el servidor usa SUPABASE_SERVICE_ROLE_KEY como secreto de respaldo.
RATE_LIMIT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_CONTACT_WHATSAPP=

# --- Panel privado del propietario (/admin) ---
# UUID de auth.users del propietario de la plataforma AgendaMe. Solo servidor.
# Sin esta variable, /admin falla cerrado (nadie puede entrar).
# Nunca commitear el valor real.
ADMIN_OWNER_USER_ID=

# Opcional. Si el proyecto llega a soportar MFA/AAL2 para el usuario propietario,
# poner en "true" para exigir nivel de verificación AAL2 antes de entrar a /admin.
# Hoy el proyecto no implementa MFA: dejar en "false" o sin definir hasta que
# exista un flujo real de verificación en dos pasos.
ADMIN_REQUIRE_AAL2=false
